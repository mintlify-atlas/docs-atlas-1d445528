  "keyFeatures": [
    "Album and sticker (lamina) collection management",
    "Catalog-based validation system",
    "Duplicate detection for repeated stickers",
    "Soft delete pattern across all entities",
    "JPA auditing with automatic timestamps",
    "OpenAPI/Swagger UI documentation",
    "Bulk upload support for stickers",
    "Generic API response wrapper",
    "H2 in-memory database for development",
    "MySQL support for production"
  ],
  "publicApiSurface": [
    "POST /api/albums - Create new album",
    "GET /api/albums - List all albums",
    "GET /api/albums/{id} - Get album by ID",
    "PUT /api/albums/{id} - Update album",
    "DELETE /api/albums/{id} - Soft delete album",
    "POST /api/albums/{albumId}/catalogo - Create catalog",
    "GET /api/albums/{albumId}/catalogo - Get catalog",
    "GET /api/albums/{albumId}/catalogo/estado - Get album statistics",
    "POST /api/laminas - Add single sticker",
    "POST /api/laminas/masivo - Bulk upload stickers",
    "GET /api/laminas - List all stickers",
    "GET /api/laminas/{id} - Get sticker by ID",
    "GET /api/laminas/album/{albumId} - Get stickers by album",
    "PUT /api/laminas/{id} - Update sticker",
    "DELETE /api/laminas/{id} - Soft delete sticker",
    "GET /api/ciudades-chile - List Chilean cities",
    "GET /api/exoplanetas - List exoplanets",
    "GET /api/equipos-futbol-espana - List Spanish football teams"
  ]
}
